{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"files": {
		"maxSize": 2097152,
		"includes": ["**", "!**/*.vue", "!**/coverage", "!**/node_modules", "!**/vendor"]
	},
	"formatter": {
		"indentStyle": "tab",
		"formatWithErrors": true,
		"lineWidth": 120
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded",
			"trailingCommas": "all"
		},
		"globals": ["cast", "Bun", "Deno"]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"correctness": {
				"noNodejsModules": "off",
				"noUndeclaredDependencies": "off"
			},
			"performance": {},
			"security": {},
			"nursery": {
				"useSortedClasses": "info"
			}
		}
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } }
}
